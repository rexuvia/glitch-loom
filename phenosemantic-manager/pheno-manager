def mine_command(args):
    """Mine outputs using phenosemantic-py."""
    if not check_phenosemantic():
        print("Cannot mine: phenosemantic-py not available.")
        return
    
    # Generate job ID
    job_id = datetime.now().strftime("%Y%m%d-%H%M%S")
    output_file = RAW_OUTPUTS_DIR / f"{job_id}.jsonl"
    
    print(f"Starting mining job: {job_id}")
    print(f"  Lexaplast: {args.lexaplast}")
    print(f"  Lexasomes: {', '.join(args.lexasome)}")
    print(f"  Count: {args.count}")
    print(f"  Output: {output_file}")
    
    # Build pheno command
    cmd = [
        "cd", str(PHENO_DIR), "&&",
        "source", ".venv/bin/activate", "&&",
        "pheno", "--mine", str(args.count),
        "--lexaplast", args.lexaplast
    ]
    
    for lexasome in args.lexasome:
        cmd.extend(["--lexasome", lexasome])
    
    if args.temperature:
        cmd.extend(["--temperature", str(args.temperature)])
    
    if args.delay:
        cmd.extend(["--delay", str(args.delay)])
    
    if args.provider:
        cmd.extend(["--provider", args.provider])
    
    if args.random_temp:
        cmd.append("--random-temp")
    
    cmd.append("--incognito")
    cmd.extend([">", str(output_file)])
    
    cmd_str = " ".join(cmd)
    
    # Record job in database
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    cursor.execute('''
    INSERT INTO jobs (id, name, lexaplast, lexasomes, count, temperature, status, start_time, output_file)
    VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)
    ''', (
        job_id,
        args.name or f"mine-{job_id}",
        args.lexaplast,
        json.dumps(args.lexasome),
        args.count,
        args.temperature,
        "running",
        datetime.now().isoformat(),
        str(output_file)
    ))
    conn.commit()
    conn.close()
    
    # Run the mining command
    print(f"\nRunning: pheno --mine {args.count} --lexaplast {args.lexaplast} ...")
    print("This may take a while. Check status with: ./pheno-manager status")
    
    try:
        # Run in background
        import threading
        
        def run_mining():
            try:
                result = subprocess.run(
                    cmd_str,
                    shell=True,
                    capture_output=True,
                    text=True
                )
                
                # Update job status
                conn = sqlite3.connect(DB_PATH)
                cursor = conn.cursor()
                
                if result.returncode == 0:
                    cursor.execute('''
                    UPDATE jobs 
                    SET status = 'completed', end_time = ?
                    WHERE id = ?
                    ''', (datetime.now().isoformat(), job_id))
                    print(f"\nMining completed: {job_id}")
                else:
                    cursor.execute('''
                    UPDATE jobs 
                    SET status = 'failed', error = ?, end_time = ?
                    WHERE id = ?
                    ''', (result.stderr, datetime.now().isoformat(), job_id))
                    print(f"\nMining failed: {result.stderr}")
                
                conn.commit()
                conn.close()
                
            except Exception as e:
                log_message(f"Error in mining thread: {e}", "ERROR")
        
        # Start mining thread
        thread = threading.Thread(target=run_mining)
        thread.daemon = True
        thread.start()
        
        print(f"\nJob {job_id} started in background.")
        print(f"Check status with: ./pheno-manager status --job {job_id}")
        
    except Exception as e:
        log_message(f"Error starting mining: {e}", "ERROR")
        print(f"Error: {e}")

def status_command(args):
    """Check status of mining jobs."""
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    
    if args.job:
        cursor.execute('''
        SELECT id, name, lexaplast, lexasomes, count, status, start_time, end_time, error
        FROM jobs WHERE id = ?
        ''', (args.job,))
    else:
        cursor.execute('''
        SELECT id, name, lexaplast, lexasomes, count, status, start_time, end_time, error
        FROM jobs 
        ORDER BY start_time DESC 
        LIMIT 10
        ''')
    
    jobs = cursor.fetchall()
    conn.close()
    
    if not jobs:
        print("No jobs found.")
        return
    
    print(f"{'ID':<15} {'Name':<20} {'Lexaplast':<15} {'Count':<6} {'Status':<10} {'Started':<20}")
    print("-" * 100)
    
    for job in jobs:
        job_id, name, lexaplast, lexasomes, count, status, start_time, end_time, error = job
        
        # Truncate long names
        if len(name) > 18:
            name = name[:15] + "..."
        
        # Format start time
        if start_time:
            try:
                start_dt = datetime.fromisoformat(start_time.replace('Z', '+00:00'))
                start_str = start_dt.strftime("%Y-%m-%d %H:%M")
            except:
                start_str = start_time[:16]
        else:
            start_str = "N/A"
        
        print(f"{job_id:<15} {name:<20} {lexaplast:<15} {count:<6} {status:<10} {start_str:<20}")
        
        if error and args.verbose:
            print(f"    Error: {error[:100]}...")

def list_jobs_command(args):
    """List all mining jobs."""
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    
    query = '''
    SELECT id, name, lexaplast, count, status, start_time, end_time
    FROM jobs
    '''
    
    if args.days:
        cursor.execute(query + ' WHERE date(start_time) >= date(?, ?) ORDER BY start_time DESC', 
                      (datetime.now().isoformat(), f"-{args.days} days"))
    else:
        cursor.execute(query + ' ORDER BY start_time DESC LIMIT ?', (args.limit or 20,))
    
    jobs = cursor.fetchall()
    conn.close()
    
    if not jobs:
        print("No jobs found.")
        return
    
    print(f"{'ID':<15} {'Name':<20} {'Lexaplast':<15} {'Count':<6} {'Status':<10} {'Duration':<10}")
    print("-" * 90)
    
    for job in jobs:
        job_id, name, lexaplast, count, status, start_time, end_time = job
        
        # Calculate duration
        duration = "N/A"
        if start_time and end_time:
            try:
                start_dt = datetime.fromisoformat(start_time.replace('Z', '+00:00'))
                end_dt = datetime.fromisoformat(end_time.replace('Z', '+00:00'))
                seconds = (end_dt - start_dt).total_seconds()
                if seconds < 60:
                    duration = f"{seconds:.0f}s"
                elif seconds < 3600:
                    duration = f"{seconds/60:.0f}m"
                else:
                    duration = f"{seconds/3600:.1f}h"
            except:
                pass
        
        print(f"{job_id:<15} {name:<20} {lexaplast:<15} {count:<6} {status:<10} {duration:<10}")

def view_outputs_command(args):
    """View outputs from a mining job."""
    if not args.job:
        print("Please specify a job ID with --job")
        return
    
    # Find output file
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    cursor.execute('SELECT output_file FROM jobs WHERE id = ?', (args.job,))
    result = cursor.fetchone()
    conn.close()
    
    if not result:
        print(f"Job {args.job} not found.")
        return
    
    output_file = Path(result[0])
    if not output_file.exists():
        print(f"Output file not found: {output_file}")
        return
    
    print(f"Outputs from job {args.job} ({output_file}):\n")
    
    count = 0
    with open(output_file, "r") as f:
        for line in f:
            if count >= (args.limit or 10):
                print(f"\n... and {sum(1 for _ in f)} more")
                break
            
            try:
                data = json.loads(line.strip())
                text = data.get("text", "").replace("\n", " ")
                if len(text) > 100:
                    text = text[:97] + "..."
                
                rating = data.get("rating", "N/A")
                print(f"{count+1:3d}. [{rating}] {text}")
                count += 1
            except json.JSONDecodeError:
                print(f"{count+1:3d}. (Invalid JSON)")
                count += 1
    
    if count == 0:
        print("No outputs found.")

def main():
    """Main entry point."""
    ensure_directories()
    
    parser = argparse.ArgumentParser(
        description="Phenosemantic Manager - User-friendly wrapper for phenosemantic-py",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  ./pheno-manager init
  ./pheno-manager create-lexaplast game-concepts --template creative
  ./pheno-manager create-lexasome mechanics --type txt
  ./pheno-manager add-to-lexasome mechanics --text "procedural generation"
  ./pheno-manager mine --lexaplast game-concepts --lexasome mechanics --count 100
  ./pheno-manager status
        """
    )
    
    subparsers = parser.add_subparsers(dest="command", help="Command to execute")
    
    # Init command
    init_parser = subparsers.add_parser("init", help="Initialize phenosemantic manager")
    
    # Lexaplast commands
    lexaplast_parser = subparsers.add_parser("create-lexaplast", help="Create a new lexaplast")
    lexaplast_parser.add_argument("name", help="Name of the lexaplast")
    lexaplast_parser.add_argument("--template", help="Template to use")
    lexaplast_parser.add_argument("--description", help="Description of the lexaplast")
    lexaplast_parser.add_argument("--interactive", action="store_true", help="Create interactively")
    lexaplast_parser.add_argument("--force", action="store_true", help="Overwrite if exists")
    
    subparsers.add_parser("list-lexaplasts", help="List all lexaplasts")
    
    # Lexasome commands
    lexasome_parser = subparsers.add_parser("create-lexasome", help="Create a new lexasome")
    lexasome_parser.add_argument("name", help="Name of the lexasome")
    lexasome_parser.add_argument("--type", choices=["txt", "csv", "json"], default="txt", 
                                help="Type of lexasome (default: txt)")
    lexasome_parser.add_argument("--force", action="store_true", help="Overwrite if exists")
    
    add_parser = subparsers.add_parser("add-to-lexasome", help="Add entries to a lexasome")
    add_parser.add_argument("name", help="Name of the lexasome")
    add_parser.add_argument("--text", required=True, help="Text to add")
    add_parser.add_argument("--weight", type=float, help="Weight for CSV lexasomes")
    
    subparsers.add_parser("list-lexasomes", help="List all lexasomes")
    
    # Mining commands
    mine_parser = subparsers.add_parser("mine", help="Mine outputs using phenosemantic-py")
    mine_parser.add_argument("--lexaplast", required=True, help="Lexaplast to use")
    mine_parser.add_argument("--lexasome", required=True, nargs="+", help="Lexasomes to use")
    mine_parser.add_argument("--count", type=int, default=100, help="Number of outputs to generate")
    mine_parser.add_argument("--temperature", type=float, help="Generation temperature")
    mine_parser.add_argument("--delay", type=int, help="Delay between API calls (ms)")
    mine_parser.add_argument("--provider", help="API provider to use")
    mine_parser.add_argument("--random-temp", action="store_true", help="Use random temperature")
    mine_parser.add_argument("--name", help="Name for this mining job")
    
    status_parser = subparsers.add_parser("status", help="Check status of mining jobs")
    status_parser.add_argument("--job", help="Specific job ID to check")
    status_parser.add_argument("--verbose", "-v", action="store_true", help="Show detailed output")
    
    list_jobs_parser = subparsers.add_parser("list-jobs", help="List mining jobs")
    list_jobs_parser.add_argument("--days", type=int, help="Show jobs from last N days")
    list_jobs_parser.add_argument("--limit", type=int, default=20, help="Maximum jobs to show")
    
    view_parser = subparsers.add_parser("view-outputs", help="View outputs from a mining job")
    view_parser.add_argument("--job", required=True, help="Job ID")
    view_parser.add_argument("--limit", type=int, default=10, help="Maximum outputs to show")
    
    # Parse arguments
    args = parser.parse_args()
    
    if not args.command:
        parser.print_help()
        return
    
    # Execute command
    try:
        if args.command == "init":
            init_command(args)
        elif args.command == "create-lexaplast":
            create_lexaplast_command(args)
        elif args.command == "list-lexaplasts":
            list_lexaplasts_command(args)
        elif args.command == "create-lexasome":
            create_lexasome_command(args)
        elif args.command == "add-to-lexasome":
            add_to_lexasome_command(args)
        elif args.command == "list-lexasomes":
            list_lexasomes_command(args)
        elif args.command == "mine":
            mine_command(args)
        elif args.command == "status":
            status_command(args)
        elif args.command == "list-jobs":
            list_jobs_command(args)
        elif args.command == "view-outputs":
            view_outputs_command(args)
        else:
            print(f"Unknown command: {args.command}")
            parser.print_help()
    
    except KeyboardInterrupt:
        print("\nInterrupted.")
        sys.exit(1)
    except Exception as e:
        log_message(f"Error in command '{args.command}': {e}", "ERROR")
        print(f"Error: {e}")
        sys.exit(1)

