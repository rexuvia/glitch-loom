def create_lexaplast_command(args):
    """Create a new lexaplast."""
    name = args.name
    lexaplast_path = LEXAPLASTS_DIR / f"{name}.json"
    
    if lexaplast_path.exists() and not args.force:
        print(f"Lexaplast '{name}' already exists. Use --force to overwrite.")
        return
    
    if args.template:
        # Load from template
        template_path = TEMPLATES_DIR / f"{args.template}.json"
        if not template_path.exists():
            print(f"Template '{args.template}' not found.")
            print(f"Available templates: {[f.stem for f in TEMPLATES_DIR.glob('*.json')]}")
            return
        
        with open(template_path, "r") as f:
            template = json.load(f)
        
        # Customize template
        template["name"] = name
        if args.description:
            template["description"] = args.description
        
        with open(lexaplast_path, "w") as f:
            json.dump(template, f, indent=2)
        
        print(f"Created lexaplast '{name}' from template '{args.template}'")
        
    elif args.interactive:
        # Interactive creation
        print(f"Creating lexaplast '{name}' interactively...")
        print("(Press Enter to use default values)")
        
        description = input("Description: ").strip() or f"Lexaplast for {name}"
        system_prompt = input("System prompt: ").strip() or "You are a helpful assistant."
        
        print("\nUser prompt template uses placeholders like {domain}, {task}, etc.")
        user_prompt = input("User prompt template: ").strip() or "Generate {domain} {task}"
        
        temperature = float(input("Temperature (0.0-1.0, default 0.8): ").strip() or "0.8")
        max_tokens = int(input("Max tokens (default 500): ").strip() or "500")
        
        lexaplast = {
            "name": name,
            "description": description,
            "system_prompt": system_prompt,
            "user_prompt_template": user_prompt,
            "parameters": {
                "temperature": temperature,
                "max_tokens": max_tokens
            }
        }
        
        with open(lexaplast_path, "w") as f:
            json.dump(lexaplast, f, indent=2)
        
        print(f"\nCreated lexaplast '{name}'")
        
    else:
        # Create minimal lexaplast
        lexaplast = {
            "name": name,
            "description": args.description or f"Lexaplast for {name}",
            "system_prompt": "You are a helpful assistant.",
            "user_prompt_template": "Generate {domain} {task}",
            "parameters": {
                "temperature": 0.8,
                "max_tokens": 500
            }
        }
        
        with open(lexaplast_path, "w") as f:
            json.dump(lexaplast, f, indent=2)
        
        print(f"Created lexaplast '{name}'")
    
    # Also create in phenosemantic-py directory for compatibility
    pheno_lexaplast_path = PHENO_LEXAPLASTS_DIR / f"{name}.json"
    if not pheno_lexaplast_path.exists():
        with open(lexaplast_path, "r") as src, open(pheno_lexaplast_path, "w") as dst:
            dst.write(src.read())
        print(f"  Also created in phenosemantic-py directory for compatibility")

def list_lexaplasts_command(args):
    """List all lexaplasts."""
    lexaplasts = list(LEXAPLASTS_DIR.glob("*.json"))
    
    if not lexaplasts:
        print("No lexaplasts found.")
        return
    
    print(f"Found {len(lexaplasts)} lexaplasts:\n")
    
    for lexaplast_path in sorted(lexaplasts):
        with open(lexaplast_path, "r") as f:
            try:
                data = json.load(f)
                name = data.get("name", lexaplast_path.stem)
                description = data.get("description", "No description")
                print(f"  {name}: {description}")
            except json.JSONDecodeError:
                print(f"  {lexaplast_path.stem}: (invalid JSON)")

def create_lexasome_command(args):
    """Create a new lexasome."""
    name = args.name
    lexasome_path = LEXASOMES_DIR / f"{name}.{args.type}"
    
    if lexasome_path.exists() and not args.force:
        print(f"Lexasome '{name}' already exists. Use --force to overwrite.")
        return
    
    # Create empty lexasome file
    if args.type == "txt":
        with open(lexasome_path, "w") as f:
            f.write("# Lexasome: {name}\n# Created: {datetime}\n\n".format(
                name=name,
                datetime=datetime.now().strftime("%Y-%m-%d %H:%M:%S")
            ))
    elif args.type == "csv":
        with open(lexasome_path, "w") as f:
            f.write("text,weight\n")
    elif args.type == "json":
        with open(lexasome_path, "w") as f:
            json.dump({
                "name": name,
                "type": "text",
                "entries": []
            }, f, indent=2)
    
    print(f"Created {args.type} lexasome '{name}' at {lexasome_path}")
    
    # Also create in phenosemantic-py directory for compatibility
    pheno_lexasome_path = PHENO_LEXASOMES_DIR / f"{name}.{args.type}"
    if not pheno_lexasome_path.exists():
        with open(lexasome_path, "r") as src, open(pheno_lexasome_path, "w") as dst:
            dst.write(src.read())
        print(f"  Also created in phenosemantic-py directory for compatibility")

def add_to_lexasome_command(args):
    """Add entries to a lexasome."""
    name = args.name
    
    # Find lexasome file
    lexasome_path = None
    for ext in ["txt", "csv", "json"]:
        path = LEXASOMES_DIR / f"{name}.{ext}"
        if path.exists():
            lexasome_path = path
            break
    
    if not lexasome_path:
        print(f"Lexasome '{name}' not found.")
        return
    
    ext = lexasome_path.suffix[1:]  # Remove dot
    
    if ext == "txt":
        with open(lexasome_path, "a") as f:
            f.write(f"{args.text}\n")
        print(f"Added '{args.text}' to lexasome '{name}'")
    
    elif ext == "csv":
        weight = args.weight or 1.0
        with open(lexasome_path, "a") as f:
            f.write(f"{args.text},{weight}\n")
        print(f"Added '{args.text}' with weight {weight} to lexasome '{name}'")
    
    elif ext == "json":
        with open(lexasome_path, "r") as f:
            data = json.load(f)
        
        if data.get("type") == "text":
            if "entries" not in data:
                data["entries"] = []
            data["entries"].append(args.text)
        elif data.get("type") == "combiner":
            if "sources" not in data:
                data["sources"] = []
            data["sources"].append(args.text)
        
        with open(lexasome_path, "w") as f:
            json.dump(data, f, indent=2)
        
        print(f"Added '{args.text}' to JSON lexasome '{name}'")
    
    # Also update in phenosemantic-py directory
    pheno_lexasome_path = PHENO_LEXASOMES_DIR / f"{name}.{ext}"
    with open(lexasome_path, "r") as src, open(pheno_lexasome_path, "w") as dst:
        dst.write(src.read())

