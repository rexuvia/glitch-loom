#!/usr/bin/env python3
"""
Phenosemantic Manager - User-friendly wrapper for phenosemantic-py
"""

import os
import sys
import json
import argparse
import subprocess
import sqlite3
from datetime import datetime
from pathlib import Path

# Configuration
BASE_DIR = Path(__file__).parent
CONFIG_DIR = BASE_DIR / "config"
LEXAPLASTS_DIR = CONFIG_DIR / "lexaplasts"
LEXASOMES_DIR = CONFIG_DIR / "lexasomes"
TEMPLATES_DIR = CONFIG_DIR / "templates"
SCRIPTS_DIR = BASE_DIR / "scripts"
DB_PATH = BASE_DIR / "db" / "pheno-manager.db"
OUTPUTS_DIR = BASE_DIR / "outputs"
RAW_OUTPUTS_DIR = OUTPUTS_DIR / "raw"
RANKED_OUTPUTS_DIR = OUTPUTS_DIR / "ranked"
CURATED_OUTPUTS_DIR = OUTPUTS_DIR / "curated"
LOGS_DIR = BASE_DIR / "logs"

# Phenosemantic-py paths
PHENO_DIR = Path("/home/ubuntu/.openclaw/workspace/phenosemantic-py")
PHENO_LEXAPLASTS_DIR = PHENO_DIR / "lexaplasts"
PHENO_LEXASOMES_DIR = PHENO_DIR / "lexasomes"

def ensure_directories():
    """Create necessary directories if they don't exist."""
    directories = [
        CONFIG_DIR, LEXAPLASTS_DIR, LEXASOMES_DIR, TEMPLATES_DIR,
        SCRIPTS_DIR, BASE_DIR / "db", OUTPUTS_DIR, RAW_OUTPUTS_DIR,
        RANKED_OUTPUTS_DIR, CURATED_OUTPUTS_DIR, LOGS_DIR
    ]
    for directory in directories:
        directory.mkdir(parents=True, exist_ok=True)

def init_database():
    """Initialize SQLite database."""
    conn = sqlite3.connect(DB_PATH)
    cursor = conn.cursor()
    
    # Jobs table
    cursor.execute('''
    CREATE TABLE IF NOT EXISTS jobs (
        id TEXT PRIMARY KEY,
        name TEXT,
        lexaplast TEXT,
        lexasomes TEXT,
        count INTEGER,
        temperature REAL,
        status TEXT,
        start_time TIMESTAMP,
        end_time TIMESTAMP,
        output_file TEXT,
        error TEXT
    )
    ''')
    
    # Scheduled jobs table
    cursor.execute('''
    CREATE TABLE IF NOT EXISTS scheduled_jobs (
        id TEXT PRIMARY KEY,
        name TEXT UNIQUE,
        lexaplast TEXT,
        lexasomes TEXT,
        count INTEGER,
        schedule_time TEXT,
        enabled BOOLEAN DEFAULT 1,
        created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
    )
    ''')
    
    # Outputs table (for tracking individual outputs)
    cursor.execute('''
    CREATE TABLE IF NOT EXISTS outputs (
        id TEXT PRIMARY KEY,
        job_id TEXT,
        text TEXT,
        rating INTEGER,
        metadata TEXT,
        created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
        FOREIGN KEY (job_id) REFERENCES jobs (id)
    )
    ''')
    
    conn.commit()
    conn.close()

def log_message(message, level="INFO"):
    """Log a message to the log file."""
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    log_entry = f"[{timestamp}] [{level}] {message}\n"
    
    log_file = LOGS_DIR / "pheno-manager.log"
    with open(log_file, "a") as f:
        f.write(log_entry)
    
    if level in ["ERROR", "WARNING"]:
        print(f"{level}: {message}")

def check_phenosemantic():
    """Check if phenosemantic-py is available."""
    if not PHENO_DIR.exists():
        log_message(f"phenosemantic-py not found at {PHENO_DIR}", "ERROR")
        return False
    
    # Check if pheno command works
    try:
        result = subprocess.run(
            ["cd", str(PHENO_DIR), "&&", "source", ".venv/bin/activate", "&&", "pheno", "--version"],
            shell=True,
            capture_output=True,
            text=True
        )
        if result.returncode != 0:
            log_message("pheno command failed. Make sure .venv is activated.", "ERROR")
            return False
    except Exception as e:
        log_message(f"Error checking phenosemantic: {e}", "ERROR")
        return False
    
    return True

